{
  "mcpServers": {
    // GitHub — personal account
    // Get a token at: https://github.com/settings/tokens
    // Scope: repo
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
